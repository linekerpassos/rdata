pages = {2437--2466},
title = {{Accounting Standards Harmonization and Financial Integration}},
volume = {36},
year = {2019}
}
@article{Joos2013,
abstract = {This paper examines the stock market reaction to 15 events relating to IFRS adoption in the United States. The goal is to assess whether investors perceive the switch to IFRS as beneficial or costly. Our findings suggest that investors' reaction to IFRS adoption is more positive in cases where IFRS is expected to lead to convergence benefits. Our results also indicate a less positive market reaction for firms with higher litigation risk, which is consistent with investors' concerns about greater discretion and less implementation guidance under IFRS for these firms. Overall, the findings are relevant to the current debate on IFRS adoption in the U.S. and highlight the importance of convergence to investors. {\textcopyright} 2013 American Accounting Association.},
author = {Joos, Philip P.M. and Leung, Edith},
doi = {10.2308/accr-50338},
file = {:C$\backslash$:/Users/linek/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Joos, Leung - 2013 - Investor perceptions of potential IFRS adoption in the United States.pdf:pdf},
issn = {00014826},
journal = {Accounting Review},
keywords = {Convergence,IFRS adoption,SEC},
number = {2},
pages = {577--609},
title = {{Investor perceptions of potential IFRS adoption in the United States}},
volume = {88},
year = {2013}
}
